OPENAI_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ca-central-1
S3_BUCKET_NAME=
WP_BASE_URL=http://cms-platform.local
# WSL2 only: Python can't resolve .local names, so point BASE_URL at
# 127.0.0.1 and set WP_HOST_HEADER to the real vhost name so nginx
# routes correctly. Leave blank in production.
WP_HOST_HEADER=
WP_USERNAME=admin
WP_APP_PASSWORD=
# Only needed locally if LocalWP has Nginx HTTP auth enabled.
WP_HTTP_USER=
WP_HTTP_PASS=
